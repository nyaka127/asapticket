# ─────────────────────────────────────────────────────────────
# ENVIRONMENT VARIABLES FOR VERCEL PRODUCTION DEPLOYMENT
# Copy these exact names into your Vercel project settings.
# ─────────────────────────────────────────────────────────────

# ── DATABASE (Vercel Postgres — auto-filled when you add Vercel Postgres) ──
DATABASE_URL="postgres://..."          # Vercel fills this automatically
DIRECT_URL="postgres://..."            # Vercel fills this automatically (direct connection)

# ── SITE ROLE (SET DIFFERENTLY FOR EACH VERCEL PROJECT) ────────────────────
# For the CLIENT ticketing site deployment:
SITE_ROLE="public"

# For the AGENT dashboard deployment:
# SITE_ROLE="admin"

# ── EMAIL (SendGrid) ────────────────────────────────────────────────────────
SENDGRID_API_KEY="SG.your_real_key_from_sendgrid.com"
FROM_EMAIL="asapticketagen7@gmail.com"

# ── SMS / WHATSAPP (Twilio) ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_token_from_twilio.com"
TWILIO_PHONE_NUMBER="+12136946417"
TWILIO_WHATSAPP_NUMBER="+12136946417"

# ── STRIPE (Payments) ───────────────────────────────────────────────────────
# Get from dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
