generator client {
  provider = "prisma-client-js"
}

datasource db {
  // --- PRODUCTION CONFIGURATION (10,000+ Users) ---
  provider = "postgresql"
  url      = env("DATABASE_URL")
  
  // --- LEGACY LOCAL (Keep for reference) ---
  // provider = "sqlite"
  // url      = "file:./dev.db"
}

model Lead {
  id                String   @id @default(uuid())
  name              String
  email             String
  phone             String
  contactMethod     String
  targetDestination String
  targetPrice       Int?
  source            String
  status            String
  createdAt         DateTime @default(now())
}

model Booking {
  id               String   @id @default(uuid())
  flightId         String
  firstName        String
  lastName         String
  email            String
  phone            String
  origin           String
  destination      String
  priceCents       Int
  paymentStatus    String
  bookingReference String
  stripePaymentIntentId String?
  status           String   @default("PENDING")
  createdAt        DateTime @default(now())
}